# EvoSync web — copie para .env e preencha com suas credenciais.
# Estas variáveis são as MESMAS usadas pelo app Python legado em ../main.py
EVO_URL=http://localhost:8080
EVO_APIKEY=
EVO_INSTANCE=

# Banco de dados SQLite (caminho do arquivo .db)
# Em produção no VPS, aponte para um path absoluto fora da pasta do app
DATABASE_URL=./data/evosync.db

# Chave mestra AES-256-GCM (32 bytes = 64 chars hex)
# Gere com: openssl rand -hex 32
# ⚠️ Se perder esta chave, as API keys da Evolution armazenadas serão IRRECUPERÁVEIS.
ENCRYPTION_KEY=

# NextAuth — segredo do JWT (criptografa o cookie de sessão)
# Gere com: openssl rand -base64 32
# ⚠️ Trocar essa chave invalida TODAS as sessões ativas.
AUTH_SECRET=
